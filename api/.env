# Copy to .env for local development
# On Railway: set these in the dashboard under Variables tab

# PostgreSQL — Railway auto-sets DATABASE_URL when you add a Postgres service
DATABASE_URL=postgresql://postgres:ZdYKzXZDbqhGtdoKtyyVFFXBGWxmYkWd@postgres.railway.internal:5432/railway

# JWT secret — any long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production

# Email — use Resend (resend.com) or leave as placeholder to skip emails
RESEND_API_KEY=placeholder

# CORS — set to your GitHub Pages URL in production
FRONTEND_URL=http://localhost:5173

# Port — Railway sets this automatically, default 3000 locally
PORT=3000
